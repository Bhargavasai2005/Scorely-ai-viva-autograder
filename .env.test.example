# Safe local test environment for batch grading diagnostics
# Copy to .env (or merge into your existing .env) before running tests.

# Use SQLite so no external DB is required
DB_CONNECTION=sqlite
DB_DATABASE=exam_history

# Turn on mock grading mode to avoid real OpenAI token spend
MOCK_GRADING=1

# Optional: keep this empty while in mock mode
OPENAI_API_KEY=

# Optional S3 values (not required for mock tests)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_URL=
